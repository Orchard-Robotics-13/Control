<include><uri>model://citrus_tree</uri><name>tree_2_9</name><pose>27 8 0 0 0 0</pose></include>

<!-- Row 3 -->
<include><uri>model://citrus_tree</uri><name>tree_3_0</name><pose>0 12 0 0 0 0</pose></include>
<include><uri>model://citrus_tree</uri><name>tree_3_1</name><pose>3 12 0 0 0 0</pose></include>
<include><uri>model://citrus_tree</uri><name>tree_3_2</name><pose>6 12 0 0 0 0</pose></include>
<include><uri>model://citrus_tree</uri><name>tree_3_3</name><pose>9 12 0 0 0 0</pose></include>
<include><uri>model://citrus_tree</uri><name>tree_3_4</name><pose>12 12 0 0 0 0</pose></include>
<include><uri>model://citrus_tree</uri><name>tree_3_5</name><pose>15 12 0 0 0 0</pose></include>
<include><uri>model://citrus_tree</uri><name>tree_3_6</name><pose>18 12 0 0 0 0</pose></include>
<include><uri>model://citrus_tree</uri><name>tree_3_7</name><pose>21 12 0 0 0 0</pose></include>
<include><uri>model://citrus_tree</uri><name>tree_3_8</name><pose>24 12 0 0 0 0</pose></include>
<include><uri>model://citrus_tree</uri><name>tree_3_9</name><pose>27 12 0 0 0 0</pose></include>
  </world>
</sdf>
